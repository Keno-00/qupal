{
  "name": "glance",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "apk": "eas build -p android --profile preview",
    "apk:local": "eas build -p android --profile preview --local",
    "test": "jest",
    "test:watch": "jest --watch",
    "validate:dataset": "node scripts/validate-dataset.js validation/manifest.json validation/predictions.json",
    "models:setup": "python -m pip install --upgrade pip && pip install -r tools/model_conversion/requirements.txt",
    "models:convert:segmentation": "python tools/model_conversion/convert_segformer_odoc_to_tflite.py --hf-model pamixsun/segformer_for_optic_disc_cup_segmentation --input-size 224 --output assets/models/glaucoma_odoc_segmentation.tflite --quantization float16"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/drawer": "^7.9.8",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/stack": "^7.8.10",
    "babel-preset-expo": "~54.0.10",
    "buffer": "^6.0.3",
    "expo": "~54.0.33",
    "expo-asset": "~12.0.12",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-file-system": "~19.0.21",
    "expo-image-manipulator": "~14.0.8",
    "expo-print": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "jpeg-js": "^0.4.4",
    "lucide-react-native": "^1.8.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-fast-tflite": "^2.0.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-nitro-modules": "^0.35.4",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "jest": "~29.7.0",
    "ts-jest": "^29.4.9",
    "typescript": "~5.9.2"
  },
  "private": true
}
