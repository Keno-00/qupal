{
  "name": "glance",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "apk": "eas build -p android --profile preview",
    "apk:local": "eas build -p android --profile preview --local",
    "test": "jest",
    "test:watch": "jest --watch",
    "validate:dataset": "node scripts/validate-dataset.js validation/manifest.json validation/predictions.json",
    "models:setup": "python -m pip install --upgrade pip && pip install -r tools/model_conversion/requirements.txt",
    "models:convert:segmentation": "python tools/model_conversion/convert_segformer_odoc_to_tflite.py --hf-model pamixsun/segformer_for_optic_disc_cup_segmentation --input-size 224 --output assets/models/glaucoma_odoc_segmentation.tflite --quantization float16"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "buffer": "^6.0.3",
    "expo": "~54.0.33",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-file-system": "~19.0.21",
    "expo-image-manipulator": "~14.0.8",
    "expo-print": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "jpeg-js": "^0.4.4",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-fast-tflite": "^2.0.0",
    "react-native-nitro-modules": "^0.35.4",
    "react-native-safe-area-context": "~5.6.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "~5.9.2"
  },
  "private": true
}
