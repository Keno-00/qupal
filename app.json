{
  "expo": {
    "name": "GLANCE",
    "slug": "glance",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "infoPlist": {
        "NSCameraUsageDescription": "Camera is required to capture fundus images for functionality testing."
      },
      "supportsTablet": true
    },
    "android": {
      "package": "com.glance.mvp",
      "permissions": [
        "CAMERA"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow GLANCE to use camera for fundus capture."
        }
      ],
      "react-native-fast-tflite"
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "aiModels": {
        "drGradingUrl": "https://raw.githubusercontent.com/drprajapati/APTOSBlindnessDetection/master/app/src/main/assets/mobile_net_v2.tflite",
        "glaucomaUrl": "https://raw.githubusercontent.com/nithin-cherukumalli/computer-vision-for-glaucoma/main/glaucoma_model.tflite"
      },
      "eas": {
        "projectId": "1f337651-8c5d-4af5-b050-dd1b1e0fbdcc"
      }
    }
  }
}
